{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:github.com)",
      "Bash(sqlite3 .wiki.db \".tables\")",
      "Bash(sqlite3 .wiki.db \".schema wikilinks\")",
      "Bash(sqlite3 .wiki.db \"SELECT name FROM sqlite_master WHERE type='table' AND name='wikilinks'\")",
      "Bash(sqlite3 .wiki.db \"SELECT COUNT\\(*\\) FROM wikilinks\")",
      "Bash(grep -E \"^\\(index|hot|log|_insights\\)\\\\.md$\")",
      "Bash(bash 0100-wiki-meta/scripts/run-lint.sh)",
      "Read(//d/obsidian/**)",
      "Bash(sqlite3 .wiki.db \"SELECT path FROM notes WHERE path LIKE '%building-effective-agents%';\")",
      "Bash(sqlite3 .wiki.db \"SELECT COUNT\\(*\\) FROM notes WHERE path LIKE '%building-effective-agents%' OR path LIKE '%contextual-retrieval%';\")",
      "Bash(sqlite3 *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python 0100-wiki-meta/scripts/validate-frontmatter.py \"$CLAUDE_TOOL_OUTPUT\" 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd D:/obsidian && git status --short 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
